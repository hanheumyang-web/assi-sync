rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    // 본인: 읽기/쓰기
    // 비인증: 읽기 허용 (포트폴리오 공개 페이지에서 프로필 표시용)
    match /users/{userId} {
      allow read: if true;
      // role 필드 변경 방지 (Admin SDK만 가능)
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == resource.data.role);
    }

    // ── Projects ──
    // 본인: 전체 읽기/쓰기
    // 비인증: portfolioPublic == true인 프로젝트만 읽기
    match /projects/{projectId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow read: if resource.data.portfolioPublic == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // ── Assets ──
    // 본인: 전체 읽기/쓰기
    // 비인증: 읽기 허용 (공개 프로젝트의 에셋 표시용, 실제 파일은 Storage URL로 접근)
    match /assets/{assetId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // ── Portfolios ──
    // 본인: 읽기/쓰기 (doc ID = uid)
    // 비인증: published == true인 포트폴리오만 읽기
    match /portfolios/{portfolioId} {
      allow read: if request.auth != null && request.auth.uid == portfolioId;
      allow read: if resource.data.published == true;
      allow write: if request.auth != null && request.auth.uid == portfolioId;
    }
  }
}
